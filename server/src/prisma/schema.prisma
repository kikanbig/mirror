generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  telegramId      BigInt    @unique
  username        String?
  firstName       String?
  birthDate       DateTime?
  birthTime       String?
  birthPlace      String?
  zodiacSign      String?
  lifePathNumber  Int?
  soulNumber      Int?
  destinyNumber   Int?
  level           Int       @default(1)
  experience      Int       @default(0)
  streak          Int       @default(0)
  lastActiveDate  DateTime?
  premiumUntil    DateTime?
  interests       String[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  readings        Reading[]
  journalEntries  JournalEntry[]
  dailyCards      DailyCard[]
  subscriptions   Subscription[]
  purchases       Purchase[]
  fateReports     FateReport[]
}

model Reading {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  type            ReadingType
  spreadType      String
  question        String?
  cards           Json
  interpretation  String?
  userNotes       String?
  mood            String?
  area            String?
  isBookmarked    Boolean     @default(false)
  createdAt       DateTime    @default(now())
}

model DailyCard {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  cardId          String
  reversed        Boolean
  interpretation  String?
  date            DateTime @db.Date
  createdAt       DateTime @default(now())

  @@unique([userId, date])
}

model JournalEntry {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  readingId String?
  content   String
  mood      String?
  tags      String[]
  createdAt DateTime @default(now())
}

model ApiLog {
  id          String   @id @default(uuid())
  provider    String
  model       String
  endpoint    String
  success     Boolean
  latencyMs   Int
  promptLen   Int
  responseLen Int      @default(0)
  error       String?
  telegramId  BigInt?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([provider])
}

model Subscription {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  type          String
  status        String   @default("active")
  startsAt      DateTime @default(now())
  expiresAt     DateTime
  telegramPayId String?
  amount        Int
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Purchase {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  product       String
  telegramPayId String?  @unique
  amount        Int
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([userId])
}

model FateReport {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  birthDate DateTime @db.Date
  chapters  Json
  wordCount Int      @default(0)
  status    String   @default("generating")
  createdAt DateTime @default(now())

  @@unique([userId, birthDate])
  @@index([userId])
}

enum ReadingType {
  TAROT
  RUNES
  ORACLE
}
